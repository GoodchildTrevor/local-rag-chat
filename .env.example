# -------------------------------------------------------
# local-rag-chat — environment variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# App
APP_PORT=8000
SESSION_TIMEOUT_MINUTES=30

# Qdrant
DB_PORT=6333
RAG_DOC_COLLECTION=rag_documents
CASH_COLLECTION=rag_cache
RAG_SNAPSHOT_DIR=/app/snapshots

# Redis
REDIS_PORT=6379

# OCR / file-worker (required by document-chunker)
FILE_WORKER_URL=http://file-worker:9000/parse
LIBREOFFICE_TIMEOUT=60

# Chunking defaults (forwarded to document-chunker and qdrant-ingester)
CHUNK_SIZE=512
OVERLAP=1

# Embedding models
DENSE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
SPARSE_MODEL_NAME=Qdrant/bm25
BATCH_SIZE=16
UPSERT_BATCH_SIZE=16
SCROLL_LIMIT=1000
