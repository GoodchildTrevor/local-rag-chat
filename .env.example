# -------------------------------------------------------
# local-rag-chat — environment variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# App
APP_PORT=8000
SESSION_TIMEOUT_MINUTES=30

# Qdrant
DB_PORT=6333
RAG_DOC_COLLECTION=rag_documents
CASH_COLLECTION=rag_cache
RAG_SNAPSHOT_DIR=/app/snapshots

# Redis
REDIS_PORT=6379

# Chunking defaults (forwarded to document-chunker and qdrant-ingester)
CHUNK_SIZE=512
OVERLAP=1

# Embedding models (used by qdrant-ingester)
DENSE_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
SPARSE_MODEL_NAME=Qdrant/bm25
BATCH_SIZE=16
UPSERT_BATCH_SIZE=16
SCROLL_LIMIT=1000

# Microservice URLs (resolved automatically inside docker-compose network)
QDRANT_SEARCHER_URL=http://qdrant-searcher:8033
QDRANT_INGESTER_URL=http://qdrant-ingester:8002
DOCUMENT_CHUNKER_URL=http://document-chunker:8001/chunk
